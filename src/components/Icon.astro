  | "code"
  | "pen"
  | "sparkles";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 16, class: className = "", strokeWidth = 1.75 } = Astro.props;

