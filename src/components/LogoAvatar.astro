---
interface Props {
  /** Domain for logo, e.g. 'medforce-ai.com'. Optional. */
  domain?: string;
  /** Manual logo URL override. Wins over the favicon-derived URL. */
  logoUrl?: string;
  /** Name (used for alt text and fallback initial). */
  name: string;
  /** Diameter in pixels. */
  size?: number;
  class?: string;
}

const { domain, logoUrl: manualUrl, name, size = 44, class: className = "" } = Astro.props;

const fallbackFavicon = domain
  ? `https://t1.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&size=256&url=https://${domain}`
  : null;
const logoUrl = manualUrl ?? fallbackFavicon;
const initial = name.charAt(0).toUpperCase();

// Manual URLs are typically horizontal brand-wordmarks pulled from a site
// header — they need padding + object-contain to render readably.
// Favicons are square icons — they should fill the avatar with object-cover.
const imgClass = manualUrl
  ? "w-full h-full object-contain p-1"
  : "w-full h-full object-cover";
---

<span
  class:list={[
    "logo-avatar relative shrink-0 inline-flex items-center justify-center rounded-md overflow-hidden bg-white ring-1 ring-ink-200 dark:ring-ink-700",
    className,
  ]}
  style={`width:${size}px;height:${size}px;`}
>
  {
    logoUrl ? (
      <>
        <img
          src={logoUrl}
          alt={`${name} logo`}
          width={size}
          height={size}
          loading="lazy"
          class={imgClass}
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
        />
        <span
          class="hidden absolute inset-0 items-center justify-center font-mono font-semibold text-ink-700 select-none"
          aria-hidden="true"
        >
          {initial}
        </span>
      </>
    ) : (
      <span class="font-mono font-semibold text-ink-700 select-none" aria-hidden="true">
        {initial}
      </span>
    )
  }
</span>
