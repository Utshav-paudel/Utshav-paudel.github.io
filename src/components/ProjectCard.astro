---
import type { Project } from "../data/projects.ts";
import Icon from "./Icon.astro";
import { site } from "../data/site.ts";

interface Props {
  project: Project;
}
const { project } = Astro.props;

type ProjectLink = { label: string; href: string; icon: "github" | "external" };
const links: ProjectLink[] = [];
if (project.repo) links.push({ label: "GitHub", href: project.repo, icon: "github" });
if (project.url) {
  const isModel = /huggingface\.co/.test(project.url);
  links.push({ label: isModel ? "Model" : "Visit", href: project.url, icon: "external" });
}
// Fall back to the GitHub profile if a project lists no links of its own.
if (links.length === 0)
  links.push({ label: "GitHub", href: `https://github.com/${site.github}`, icon: "github" });
---

<div
  class="not-prose font-sans group rounded-lg border border-parchment-border dark:border-ember-border bg-parchment-50 dark:bg-ember-900 p-4 sm:p-5 hover:border-parchment-200 dark:hover:border-ember-700 hover:shadow-[0_1px_0_rgba(0,0,0,0.04)] dark:hover:shadow-none transition-all"
>
  <div class="flex items-start gap-3">
    {project.glyph && (
      <div
        class:list={[
          "shrink-0 w-10 h-10 rounded-md flex items-center justify-center text-lg",
          project.glyphAccent ?? "bg-ink-100 text-ink-700 dark:bg-ink-800 dark:text-ink-300",
        ]}
        aria-hidden="true"
      >
        {project.glyph}
      </div>
    )}
    <div class="min-w-0 flex-1">
      <h3 class="font-medium text-ink-900 dark:text-ink-100 text-base leading-tight">
        {project.name}
      </h3>
      {project.domain && (
        <span
          class:list={[
            "inline-block mt-1.5 font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded",
            project.domainAccent ?? "bg-ink-100 text-ink-700 dark:bg-ink-800 dark:text-ink-300",
          ]}
        >
          {project.domain}
        </span>
      )}
    </div>
  </div>

  <p class="mt-3 font-editorial text-[15.5px] text-ink-800 dark:text-ink-200 leading-[1.55]">
    {project.tagline}
  </p>

  <div class="mt-3 flex flex-wrap gap-1.5">
    {
      project.stack.map((t) => (
        <span class="font-mono text-[10.5px] px-1.5 py-0.5 rounded bg-ink-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-800 text-ink-600 dark:text-ink-400">
          {t}
        </span>
      ))
    }
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    {
      links.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 font-mono text-[11px] px-2.5 py-1 rounded-md border border-ink-200 dark:border-ink-700 text-ink-600 dark:text-ink-300 hover:border-ink-400 dark:hover:border-ink-500 hover:text-ink-900 dark:hover:text-ink-100 transition-colors"
        >
          <Icon name={l.icon} size={12} />
          {l.label}
        </a>
      ))
    }
  </div>
</div>
