---
import type { Experience } from "../data/experience.ts";
import Icon from "./Icon.astro";

interface Props {
  job: Experience;
  /** Show all bullets, vs. only first one (used on home for compactness). */
  expanded?: boolean;
}

const { job, expanded = true } = Astro.props;
const initial = job.initial ?? job.company.charAt(0);
const accent = job.accent ?? "bg-ink-200 text-ink-700 dark:bg-ink-800 dark:text-ink-300";
const bullets = expanded ? job.bullets : job.bullets.slice(0, 1);
---

<article class="not-prose group relative rounded-lg border border-ink-200 dark:border-ink-800 p-4 sm:p-5 hover:border-ink-300 dark:hover:border-ink-700 transition-colors">
  <header class="flex items-start gap-3 sm:gap-4">
    <div
      class:list={[
        "shrink-0 w-10 h-10 sm:w-11 sm:h-11 rounded-md flex items-center justify-center font-mono font-semibold text-base sm:text-lg",
        accent,
      ]}
      aria-hidden="true"
    >
      {initial}
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-baseline gap-2 flex-wrap">
        <h3 class="font-medium text-ink-900 dark:text-ink-100 text-base sm:text-[17px] leading-tight">
          {job.role}
        </h3>
        {job.current && (
          <span class="inline-flex items-center gap-1 font-mono text-[10px] uppercase tracking-wider text-emerald-700 dark:text-emerald-400">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" />
            current
          </span>
        )}
      </div>
      <div class="mt-0.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-ink-600 dark:text-ink-400">
        <span class="font-medium text-blue-700 dark:text-blue-400">{job.company}</span>
        <span class="text-ink-400" aria-hidden="true">·</span>
        <span class="inline-flex items-center gap-1">
          <Icon name="map-pin" size={12} class="text-ink-400" />
          {job.location}
        </span>
      </div>
    </div>

    <time class="font-mono text-[11px] sm:text-xs text-ink-500 dark:text-ink-400 whitespace-nowrap pt-1">
      {job.start} → {job.end}
    </time>
  </header>

  <ul class="mt-3 sm:mt-4 sm:pl-[60px] space-y-1.5 text-sm text-ink-700 dark:text-ink-300 leading-relaxed">
    {
      bullets.map((b) => (
        <li class="flex gap-2">
          <span class="text-ink-400 select-none mt-1 shrink-0" aria-hidden="true">›</span>
          <span>{b}</span>
        </li>
      ))
    }
  </ul>
</article>
