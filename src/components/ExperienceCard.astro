---
import type { Experience } from "../data/experience.ts";
import Icon from "./Icon.astro";
import LogoAvatar from "./LogoAvatar.astro";

interface Props {
  job: Experience;
}

const { job } = Astro.props;
---

<article class="not-prose font-sans group relative rounded-lg border border-ink-200 dark:border-ink-800 p-4 sm:p-6 hover:border-ink-300 dark:hover:border-ink-700 transition-colors">
  <header class="flex items-start gap-3 sm:gap-4">
    <LogoAvatar domain={job.companyDomain} logoUrl={job.logoUrl} bgClass={job.logoBg} name={job.company} size={44} />

    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-2 flex-wrap">
        <div class="flex items-baseline gap-2 flex-wrap min-w-0">
          <h3 class="font-medium text-ink-900 dark:text-ink-100 text-base sm:text-[17px] leading-snug">
            {job.role}
          </h3>
          {job.current && (
            <span class="inline-flex items-center gap-1 font-mono text-[10px] uppercase tracking-wider text-emerald-700 dark:text-emerald-400">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" />
              current
            </span>
          )}
        </div>
        <time class="font-mono text-[11px] sm:text-xs text-ink-500 dark:text-ink-400 whitespace-nowrap pt-1">
          {job.start} → {job.end}
        </time>
      </div>
      <div class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-0.5 text-sm text-ink-600 dark:text-ink-400">
        {job.companyUrl ? (
          <a
            href={job.companyUrl}
            target="_blank"
            rel="noopener"
            class="font-medium text-blue-700 dark:text-blue-400 hover:underline decoration-dotted underline-offset-2"
          >
            {job.company}
          </a>
        ) : (
          <span class="font-medium text-ink-800 dark:text-ink-200">{job.company}</span>
        )}
        <span class="text-ink-300 dark:text-ink-700" aria-hidden="true">·</span>
        <span class="inline-flex items-center gap-1">
          <Icon name="map-pin" size={12} class="text-ink-400" />
          {job.location}
        </span>
      </div>
    </div>
  </header>

  <ul class="mt-3.5 sm:pl-[60px] space-y-1.5 text-[14.5px] sm:text-[15px] text-ink-700 dark:text-ink-300 leading-[1.55]">
    {
      job.bullets.map((b) => (
        <li class="flex gap-2.5">
          <span class="text-ink-400 dark:text-ink-600 select-none mt-[3px] shrink-0" aria-hidden="true">›</span>
          <span>{b}</span>
        </li>
      ))
    }
  </ul>
</article>
