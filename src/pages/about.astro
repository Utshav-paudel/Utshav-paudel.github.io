---
import Layout from "../layouts/Layout.astro";
import Cell from "../components/Cell.astro";
import Icon from "../components/Icon.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import SkillItem from "../components/SkillItem.astro";
import { site } from "../data/site.ts";
import { experience } from "../data/experience.ts";
import { skillGroups, education } from "../data/skills.ts";
---

<Layout filename="about.ipynb" title={`About · ${site.name}`}>
  <div class="px-4 sm:px-10 py-8 sm:py-10 border-b border-ink-200 dark:border-ink-800">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div class="min-w-0">
        <h1 class="text-3xl font-medium tracking-tight text-ink-900 dark:text-ink-100">About</h1>
        <p class="mt-1 text-ink-500 dark:text-ink-400 text-sm font-mono">about.ipynb</p>
      </div>
      <a
        href="/cv.pdf"
        download="utshav-paudel-cv.pdf"
        class="inline-flex items-center gap-2 px-3.5 py-2 rounded-md border border-ink-300 dark:border-ink-700 text-sm font-medium hover:border-ink-500 dark:hover:border-ink-400 transition-colors"
      >
        <Icon name="download" size={15} />
        Download CV
      </a>
    </div>
    <p class="mt-5 text-ink-700 dark:text-ink-300 leading-relaxed text-[15px] max-w-2xl">
      {site.bio}
    </p>
    <p class="mt-3 flex items-center gap-1.5 text-sm text-ink-500 dark:text-ink-400">
      <Icon name="map-pin" size={14} />
      {site.location}
    </p>
  </div>

  <Cell kind="markdown" count={null}>
    <div class="flex items-center gap-2 text-ink-700 dark:text-ink-300">
      <Icon name="briefcase" size={16} class="text-ink-500" />
      <h2 class="text-base font-medium tracking-tight">Timeline</h2>
    </div>
  </Cell>

  <Cell kind="code" count={1}>
    <span>experience.<span class="text-blue-600 dark:text-blue-400">timeline</span>()</span>
  </Cell>

  <Cell kind="output" count={1} attached>
    <div class="not-prose space-y-3">
      {experience.map((job) => <ExperienceCard job={job} expanded={true} />)}
    </div>
  </Cell>

  <Cell kind="markdown" count={null}>
    <div class="flex items-center gap-2 text-ink-700 dark:text-ink-300">
      <Icon name="sparkles" size={16} class="text-ink-500" />
      <h2 class="text-base font-medium tracking-tight">Skills</h2>
    </div>
  </Cell>

  <Cell kind="code" count={2}>
    <span>utshav.<span class="text-blue-600 dark:text-blue-400">skills</span></span>
  </Cell>

  <Cell kind="output" count={2} attached>
    <div class="not-prose space-y-5">
      {
        skillGroups.map((group) => (
          <div>
            <h3 class="font-mono text-[11px] uppercase tracking-wider text-ink-500 dark:text-ink-400 mb-2">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((s) => <SkillItem skill={s} />)}
            </div>
          </div>
        ))
      }
    </div>
  </Cell>

  <Cell kind="markdown" count={null}>
    <div class="flex items-center gap-2 text-ink-700 dark:text-ink-300">
      <Icon name="file-text" size={16} class="text-ink-500" />
      <h2 class="text-base font-medium tracking-tight">Education</h2>
    </div>
  </Cell>

  <Cell kind="code" count={3}>
    <span>utshav.<span class="text-blue-600 dark:text-blue-400">education</span></span>
  </Cell>

  <Cell kind="output" count={3} attached>
    <div class="not-prose">
      <div class="font-medium text-ink-900 dark:text-ink-100">{education.degree}</div>
      <div class="text-sm text-ink-600 dark:text-ink-400">{education.school} · {education.location}</div>
      <div class="font-mono text-xs text-ink-500 mt-1">{education.start} → {education.end}</div>
    </div>
  </Cell>
</Layout>
