---
import Layout from "../layouts/Layout.astro";
import Cell from "../components/Cell.astro";
import { site } from "../data/site.ts";
import { experience } from "../data/experience.ts";
import { skills, education } from "../data/skills.ts";
---

<Layout filename="about.ipynb" title={`About — ${site.name}`}>
  <Cell kind="markdown" count={null}>
    <h1 class="text-2xl font-medium tracking-tight text-ink-900 dark:text-ink-100">About</h1>
    <p class="text-ink-600 dark:text-ink-400 text-sm mt-1 font-mono">notebook · about.ipynb</p>
  </Cell>

  <Cell kind="code" count={1}>
    <span class="text-purple-600 dark:text-purple-400">print</span>(utshav.<span class="text-blue-600 dark:text-blue-400">bio</span>)
  </Cell>

  <Cell kind="output" count={1} attached>
    <p class="text-ink-700 dark:text-ink-300 leading-relaxed font-sans text-[15px] max-w-2xl">
      {site.bio}
    </p>
  </Cell>

  <Cell kind="code" count={2}>
    <span>utshav.<span class="text-blue-600 dark:text-blue-400">timeline</span>()</span>
  </Cell>

  <Cell kind="output" count={2} attached>
    <ol class="not-prose relative border-l-2 border-ink-200 dark:border-ink-800 pl-6 space-y-6 ml-2">
      {
        experience.map((job) => (
          <li class="relative">
            <span class="absolute -left-[33px] top-1.5 w-3 h-3 rounded-full bg-white dark:bg-ink-900 border-2 border-blue-500 dark:border-blue-400"></span>
            <div class="font-mono text-[11px] text-ink-500 dark:text-ink-400">
              {job.start} → {job.end} · {job.location}
            </div>
            <div class="mt-1">
              <span class="font-medium text-ink-900 dark:text-ink-100">{job.role}</span>
              <span class="text-ink-500"> @ </span>
              <span class="text-blue-700 dark:text-blue-400 font-medium">{job.company}</span>
            </div>
            <ul class="mt-2 space-y-1.5 text-sm text-ink-700 dark:text-ink-300 leading-relaxed">
              {job.bullets.map((b) => (
                <li class="flex gap-2">
                  <span class="text-ink-400 select-none">›</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </Cell>

  <Cell kind="code" count={3}>
    <span>utshav.<span class="text-blue-600 dark:text-blue-400">skills</span></span>
  </Cell>

  <Cell kind="output" count={3} attached>
    <div class="not-prose space-y-3">
      {
        Object.entries(skills).map(([category, items]) => (
          <div>
            <span class="font-mono text-xs text-ink-500 dark:text-ink-400">{category}:</span>
            <span class="ml-2 inline-flex flex-wrap gap-1.5">
              {items.map((skill) => (
                <span class="font-mono text-xs px-2 py-0.5 rounded bg-ink-100 dark:bg-ink-800 text-ink-700 dark:text-ink-300">
                  {skill}
                </span>
              ))}
            </span>
          </div>
        ))
      }
    </div>
  </Cell>

  <Cell kind="code" count={4}>
    <span>utshav.<span class="text-blue-600 dark:text-blue-400">education</span></span>
  </Cell>

  <Cell kind="output" count={4} attached>
    <div class="not-prose">
      <div class="font-medium text-ink-900 dark:text-ink-100">{education.degree}</div>
      <div class="text-sm text-ink-600 dark:text-ink-400">{education.school} · {education.location}</div>
      <div class="font-mono text-xs text-ink-500 mt-1">{education.start} → {education.end}</div>
    </div>
  </Cell>
</Layout>
