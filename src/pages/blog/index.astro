---
import Layout from "../../layouts/Layout.astro";
import Cell from "../../components/Cell.astro";
import Icon from "../../components/Icon.astro";
import { getCollection } from "astro:content";
import { site } from "../../data/site.ts";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Layout filename="blog.ipynb" title={`Blog · ${site.name}`}>
  <div class="px-4 sm:px-10 py-8 sm:py-10 border-b border-ink-200 dark:border-ink-800">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-3xl font-medium tracking-tight text-ink-900 dark:text-ink-100">Blog</h1>
        <p class="mt-2 text-ink-600 dark:text-ink-400 max-w-xl">Notes from the kernel. On AI, building things, and the messy bits in between.</p>
      </div>
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-300 dark:border-ink-700 text-sm hover:border-ink-500 dark:hover:border-ink-400 transition-colors"
      >
        <Icon name="rss" size={14} />
        RSS
      </a>
    </div>
  </div>

  <Cell kind="code" count={1}>
    <span>posts.</span><span class="text-blue-600 dark:text-blue-400">all</span>()
  </Cell>

  <Cell kind="output" count={1} attached>
    {posts.length === 0 ? (
      <div class="text-ink-500 italic font-mono text-sm">[]  # no posts yet</div>
    ) : (
      <ul class="not-prose divide-y divide-ink-200 dark:divide-ink-800 -my-3">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.slug}/`}
              class="group block py-4 hover:bg-ink-50 dark:hover:bg-ink-800/30 -mx-2 px-2 rounded transition-colors"
            >
              <div class="flex items-baseline justify-between gap-3">
                <h2 class="font-sans text-lg font-medium text-ink-900 dark:text-ink-100 group-hover:underline decoration-dotted">
                  {post.data.title}
                </h2>
                <time class="font-mono text-xs text-ink-500 shrink-0" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </time>
              </div>
              <p class="text-sm text-ink-600 dark:text-ink-400 mt-1 leading-relaxed">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1">
                  {post.data.tags.map((t) => (
                    <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-ink-100 dark:bg-ink-800 text-ink-600 dark:text-ink-400">
                      #{t}
                    </span>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </Cell>

  {allTags.length > 0 && (
    <>
      <Cell kind="code" count={2}>
        <span>posts.<span class="text-blue-600 dark:text-blue-400">tags</span>.unique()</span>
      </Cell>
      <Cell kind="output" count={2} attached>
        <div class="flex flex-wrap gap-2 not-prose">
          {allTags.map((t) => (
            <span class="font-mono text-xs px-2 py-1 rounded bg-ink-100 dark:bg-ink-800 text-ink-700 dark:text-ink-300">
              #{t}
            </span>
          ))}
        </div>
      </Cell>
    </>
  )}
</Layout>
