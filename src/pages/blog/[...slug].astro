---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Cell from "../../components/Cell.astro";
import { site } from "../../data/site.ts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"blog"> };
const { post } = Astro.props;
const { Content } = await post.render();
const date = post.data.pubDate.toISOString().slice(0, 10);
---

<Layout
  filename={`${post.slug}.ipynb`}
  title={`${post.data.title} · ${site.name}`}
  description={post.data.description}
>
  <Cell kind="markdown" count={null}>
    <div class="font-mono text-[11px] text-ink-500 dark:text-ink-400">
      <a href="/blog/" class="hover:underline">../blog</a> / {post.slug}.ipynb
    </div>
    <h1 class="mt-3 text-3xl sm:text-4xl font-medium tracking-tight text-ink-900 dark:text-ink-100 leading-tight">
      {post.data.title}
    </h1>
    <p class="mt-3 text-ink-600 dark:text-ink-400 text-base">{post.data.description}</p>
    <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-xs text-ink-500">
      <time datetime={post.data.pubDate.toISOString()}>{date}</time>
      {post.data.tags.length > 0 && (
        <>
          <span aria-hidden="true">·</span>
          <span class="flex flex-wrap gap-1.5">
            {post.data.tags.map((t) => <span>#{t}</span>)}
          </span>
        </>
      )}
    </div>
  </Cell>

  <Cell kind="markdown" count={null}>
    <div
      class="prose prose-ink dark:prose-invert max-w-none
             prose-headings:font-sans prose-headings:font-medium prose-headings:tracking-tight
             prose-h2:mt-10 prose-h2:mb-3 prose-h2:text-2xl
             prose-h3:mt-8 prose-h3:mb-2 prose-h3:text-xl
             prose-p:leading-relaxed prose-p:text-ink-800 dark:prose-p:text-ink-200
             prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline prose-a:decoration-dotted
             prose-strong:text-ink-900 dark:prose-strong:text-ink-100
             prose-blockquote:border-l-blue-500 prose-blockquote:text-ink-600 dark:prose-blockquote:text-ink-400 prose-blockquote:not-italic
             prose-li:text-ink-800 dark:prose-li:text-ink-200
             prose-img:rounded-md prose-img:border prose-img:border-ink-200 dark:prose-img:border-ink-800"
    >
      <Content />
    </div>
  </Cell>

  <Cell kind="code" count={null}>
    <span class="text-ink-400"># end of notebook</span><br />
    <span><a href="/blog/" class="text-blue-600 dark:text-blue-400 hover:underline">posts.next()</a> · <a href="/" class="text-blue-600 dark:text-blue-400 hover:underline">home()</a></span>
  </Cell>
</Layout>
