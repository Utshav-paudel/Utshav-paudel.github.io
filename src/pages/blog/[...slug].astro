---
import Layout from "../../layouts/Layout.astro";
import Cell from "../../components/Cell.astro";
import { listEntries, toMeta } from "../../lib/blog.ts";
import { site } from "../../data/site.ts";

export async function getStaticPaths() {
  const entries = await listEntries();
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const post = toMeta(entry);
// Astro renders the MDX body and highlights code blocks with the Shiki themes
// configured in astro.config.mjs (github-light / github-dark).
const { Content } = await entry.render();
---

<Layout
  filename={`${post.slug}.ipynb`}
  title={`${post.title} · ${site.name}`}
  description={post.brief}
>
  <Cell kind="markdown" count={null}>
    <div class="font-mono text-[11px] text-ink-500 dark:text-ink-400">
      <a href="/blog/" class="hover:underline">../blog</a> / {post.slug}.ipynb
    </div>
    <h1 class="mt-3 text-3xl sm:text-4xl font-medium tracking-tight text-ink-900 dark:text-ink-100 leading-tight">
      {post.title}
    </h1>
    {post.brief && (
      <p class="mt-3 font-editorial text-ink-700 dark:text-ink-300 text-[17px] sm:text-[18px] leading-[1.55]">{post.brief}</p>
    )}
    <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-xs text-ink-500">
      <time datetime={post.isoDate}>{post.date}</time>
      <span aria-hidden="true">·</span>
      <span>{post.readTimeInMinutes} min read</span>
      {post.tags.length > 0 && (
        <>
          <span aria-hidden="true">·</span>
          <span class="flex flex-wrap gap-1.5">
            {post.tags.map((t) => <span>#{t}</span>)}
          </span>
        </>
      )}
    </div>
  </Cell>

  {post.coverImage && (
    <Cell kind="output" count={null}>
      <img
        src={post.coverImage}
        alt=""
        class="not-prose w-full rounded-md border border-ink-200 dark:border-ink-800"
        loading="eager"
      />
    </Cell>
  )}

  <Cell kind="markdown" count={null}>
    <div
      class="prose prose-ink dark:prose-invert max-w-none font-editorial
             prose-headings:font-sans prose-headings:font-semibold prose-headings:tracking-tight
             prose-h2:mt-10 prose-h2:mb-3 prose-h2:text-2xl
             prose-h3:mt-8 prose-h3:mb-2 prose-h3:text-xl
             prose-p:text-[17px] prose-p:leading-[1.7] prose-p:text-ink-800 dark:prose-p:text-ink-200
             prose-a:text-blue-700 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline prose-a:decoration-dotted prose-a:font-medium
             prose-strong:text-ink-900 dark:prose-strong:text-ink-100 prose-strong:font-semibold
             prose-blockquote:border-l-blue-500 prose-blockquote:text-ink-600 dark:prose-blockquote:text-ink-400 prose-blockquote:not-italic
             prose-li:text-[17px] prose-li:leading-[1.7] prose-li:text-ink-800 dark:prose-li:text-ink-200
             prose-img:rounded-md prose-img:border prose-img:border-parchment-border dark:prose-img:border-ember-border
             prose-pre:bg-parchment-50 dark:prose-pre:bg-ember-900 prose-pre:border prose-pre:border-parchment-border dark:prose-pre:border-ember-border
             prose-code:font-mono prose-code:before:content-none prose-code:after:content-none"
    >
      <Content />
    </div>
  </Cell>

  <Cell kind="code" count={null}>
    <span class="text-ink-400"># end of notebook</span><br />
    <span>
      <a href="/blog/" class="text-blue-600 dark:text-blue-400 hover:underline">posts.next()</a>
    </span>
  </Cell>
</Layout>
