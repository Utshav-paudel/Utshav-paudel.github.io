---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import { site } from "../data/site.ts";
import { experience } from "../data/experience.ts";
import { projects } from "../data/projects.ts";
import { skillGroups, education } from "../data/skills.ts";
import { listPosts } from "../lib/hashnode.ts";

const canonical = new URL("/cv/", site.url).toString();

// Pull up to 3 most recent Hashnode posts for the "Selected Writing" section.
// If the Hashnode fetch fails at build time, gracefully render an empty list.
let writing: { title: string; url: string; publishedAt: string }[] = [];
try {
  const posts = await listPosts(3);
  writing = posts.slice(0, 3).map((p) => ({
    title: p.title,
    url: new URL(`/blog/${p.slug}/`, site.url).toString(),
    publishedAt: p.publishedAt,
  }));
} catch {
  writing = [];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV · {site.name}</title>
    <meta name="description" content={`Curriculum Vitae of ${site.name}`} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root { color-scheme: light; }
      body {
        font-family: "Inter", system-ui, sans-serif;
        background: #fafaf9;
        color: #1c1917;
        -webkit-font-smoothing: antialiased;
        margin: 0;
      }
      .cv-page { max-width: 820px; margin: 0 auto; padding: 3rem 2.5rem; }
      .controls {
        position: sticky; top: 0; z-index: 10;
        background: rgba(250, 250, 249, 0.92); backdrop-filter: blur(8px);
        padding: 0.75rem 2.5rem; border-bottom: 1px solid #e7e5e4;
        display: flex; justify-content: space-between; align-items: center;
        font-size: 13px;
      }
      .controls a, .controls button {
        font-family: inherit; font-size: 13px; color: #1c1917;
        padding: 0.5rem 0.85rem; border: 1px solid #d6d3d1; border-radius: 6px;
        background: white; cursor: pointer; text-decoration: none;
        display: inline-flex; align-items: center; gap: 0.4rem; margin-left: 0.5rem;
      }
      .controls a:hover, .controls button:hover { border-color: #78716c; }
      h1 { font-size: 2rem; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 0.25rem; }
      .subtitle { color: #57534e; font-size: 1rem; margin: 0 0 0.75rem; }
      .meta { display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; font-size: 0.875rem; color: #57534e; }
      .meta a { color: #2563eb; text-decoration: none; }
      .meta a:hover { text-decoration: underline; }
      h2 {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem; font-weight: 500; text-transform: uppercase;
        letter-spacing: 0.12em; color: #78716c;
        margin: 2.25rem 0 0.85rem; padding-bottom: 0.4rem; border-bottom: 1px solid #e7e5e4;
      }
      .row {
        display: grid; grid-template-columns: 1fr auto;
        gap: 0.5rem 1rem; margin-bottom: 1.1rem;
      }
      .row h3 { font-size: 1rem; font-weight: 600; margin: 0 0 0.15rem; }
      .row .org { font-size: 0.95rem; color: #2563eb; font-weight: 500; }
      .row .where { font-size: 0.85rem; color: #57534e; margin-top: 0.05rem; }
      .row time { font-family: "JetBrains Mono", monospace; font-size: 0.78rem; color: #57534e; white-space: nowrap; }
      ul.bullets { list-style: none; padding: 0; margin: 0.55rem 0 0; }
      ul.bullets li { font-size: 0.93rem; color: #44403c; line-height: 1.55; padding-left: 1rem; position: relative; margin-bottom: 0.3rem; }
      ul.bullets li::before { content: "›"; position: absolute; left: 0; color: #a8a29e; }
      .skill-row { display: grid; grid-template-columns: 130px 1fr; gap: 0.5rem 0.75rem; margin-bottom: 0.5rem; font-size: 0.92rem; }
      .skill-row .cat { font-family: "JetBrains Mono", monospace; font-size: 0.78rem; color: #78716c; }
      .skill-row .items { color: #292524; }
      .project { margin-bottom: 1rem; }
      .project h3 { font-size: 0.98rem; font-weight: 600; margin: 0 0 0.15rem; }
      .project .stack { font-family: "JetBrains Mono", monospace; font-size: 0.78rem; color: #78716c; margin-bottom: 0.35rem; }
      .project p { font-size: 0.93rem; color: #44403c; margin: 0; line-height: 1.55; }
      ul.writing { list-style: none; padding: 0; margin: 0; }
      ul.writing li { font-size: 0.93rem; color: #44403c; line-height: 1.55; margin-bottom: 0.35rem; display: grid; grid-template-columns: 1fr auto; gap: 0.5rem 1rem; }
      ul.writing a { color: #2563eb; text-decoration: none; }
      ul.writing a:hover { text-decoration: underline; }
      ul.writing time { font-family: "JetBrains Mono", monospace; font-size: 0.78rem; color: #57534e; white-space: nowrap; }
      .placeholder { font-size: 0.9rem; color: #78716c; font-style: italic; }

      @media print {
        body { background: white; }
        .controls { display: none; }
        .cv-page { padding: 0.6in; max-width: none; }
        h2 { margin-top: 1.4rem; }
        a { color: #1c1917; text-decoration: none; }
        @page { margin: 0.6in; }
      }

      @media (max-width: 540px) {
        .cv-page { padding: 1.5rem 1.25rem; }
        .controls { padding: 0.6rem 1.25rem; flex-wrap: wrap; gap: 0.5rem; }
        .row { grid-template-columns: 1fr; }
        .row time { order: -1; font-size: 0.72rem; }
      }
    </style>
  </head>
  <body>
    <div class="controls">
      <a href="/"><Icon name="arrow-right" size={13} class="rotate-180" /> back to site</a>
      <div>
        <button type="button" onclick="window.print()">
          Save as PDF / Print
        </button>
        <a href="/cv.pdf" download={`${site.name.replace(" ", "-").toLowerCase()}-cv.pdf`}>Download PDF</a>
      </div>
    </div>

    <article class="cv-page">
      <h1>{site.name}</h1>
      <p class="subtitle">{site.headline}</p>
      <div class="meta">
        <span>📍 {site.location}</span>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={`https://github.com/${site.github}`} target="_blank" rel="noopener">github.com/{site.github}</a>
        <a href={`https://linkedin.com/in/${site.linkedin}`} target="_blank" rel="noopener">linkedin.com/in/{site.linkedin}</a>
      </div>

      <h2>Education</h2>
      <div class="row">
        <div>
          <h3>{education.degree}</h3>
          <div class="org">{education.school}</div>
          <div class="where">{education.location}</div>
        </div>
        <time>{education.start} → {education.end}</time>
      </div>

      <h2>Experience</h2>
      {
        experience.map((job) => (
          <div>
            <div class="row">
              <div>
                <h3>{job.role}</h3>
                <div class="org">{job.company}</div>
                <div class="where">{job.location}</div>
              </div>
              <time>{job.start} → {job.end}</time>
            </div>
            <ul class="bullets">
              {job.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))
      }

      <h2>Projects</h2>
      {
        projects.map((p) => (
          <div class="project">
            <h3>{p.name}</h3>
            <div class="stack">{p.stack.join(" · ")}</div>
            <p>{p.tagline}</p>
          </div>
        ))
      }

      <h2>Skills</h2>
      {
        skillGroups.map((group) => (
          <div class="skill-row">
            <div class="cat">{group.category}</div>
            <div class="items">{group.items.map((s) => s.name).join(", ")}</div>
          </div>
        ))
      }

      <h2>Selected Writing</h2>
      {writing.length > 0 ? (
        <ul class="writing">
          {writing.map((w) => (
            <li>
              <a href={w.url}>{w.title}</a>
              <time>{w.publishedAt.slice(0, 10)}</time>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">See <a href="/blog/" style="color:#2563eb;text-decoration:none">utshavpaudel.com.np/blog</a> for recent posts.</p>
      )}

      <h2>Open Source / Talks</h2>
      <p class="placeholder">Forthcoming: signature open-source project on clinical LLM evaluation in development. Updates at <a href={`https://github.com/${site.github}`} style="color:#2563eb;text-decoration:none">github.com/{site.github}</a>.</p>
    </article>
  </body>
</html>
